<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".ui.detail.DetailFragment">

    <!-- AppBar with collapsing toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@color/colorBackground"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/colorBackground"
            app:titleEnabled="false">

            <!-- Hero Image -->
            <ImageView
                android:id="@+id/iv_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_desc_news_image"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7"
                tools:src="@color/colorSurfaceVariant" />

            <!-- Gradient overlay on image -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_image_gradient"
                app:layout_collapseMode="parallax" />

            <!-- Toolbar -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:navigationContentDescription="@string/content_desc_back"
                style="@style/Widget.NNews.Toolbar">

                <!-- Bookmark button -->
                <ImageButton
                    android:id="@+id/btn_bookmark"
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:layout_gravity="end"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_bookmark_icon"
                    android:src="@drawable/ic_bookmark"
                    android:tint="@color/colorOnBackground" />

            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Category Tag -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_category"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                tools:text="Technology" />

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:lineSpacingMultiplier="1.3"
                android:textColor="@color/colorOnBackground"
                android:textSize="@dimen/text_xxl"
                android:textStyle="bold"
                tools:text="Breaking News Title Goes Here For Testing Purposes" />

            <!-- Source & Date Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_source"
                    android:tint="@color/colorPrimaryBrand"
                    android:contentDescription="@string/label_source" />

                <TextView
                    android:id="@+id/tv_source"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/colorPrimaryBrand"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    tools:text="BBC News" />

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/colorOnSurfaceVariant"
                    android:contentDescription="@string/label_published_at" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_sm"
                    tools:text="2024-01-01" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="@color/colorDivider" />

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:lineSpacingMultiplier="1.6"
                android:textColor="@color/colorOnBackground"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                tools:text="Short description of the article goes here." />

            <!-- Content -->
            <TextView
                android:id="@+id/tv_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:lineSpacingMultiplier="1.6"
                android:textColor="@color/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body"
                tools:text="Full article content goes here. This is a longer text that describes the news article in detail." />

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xl"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Share Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:text="@string/label_share"
                    app:icon="@drawable/ic_share" />

                <!-- Open in Browser Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_browser"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_open_browser"
                    app:icon="@drawable/ic_open_browser" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>